        "def merge_count(arr):\n",
        "    if len(arr) <= 1:\n",
        "        return arr, 0\n",
        "\n",
        "    mid = len(arr)//2\n",
        "    left, inv1 = merge_count(arr[:mid])\n",
        "    right, inv2 = merge_count(arr[mid:])\n",
        "\n",
        "    merged = []\n",
        "    i=j=inv=0\n",
        "\n",
        "    while i<len(left) and j<len(right):\n",
        "        if left[i] <= right[j]:\n",
        "            merged.append(left[i]); i+=1\n",
        "        else:\n",
        "            merged.append(right[j]); j+=1\n",
        "            inv += len(left)-i\n",
        "\n",
        "    merged += left[i:]\n",
        "    merged += right[j:]\n",
        "\n",
        "    return merged, inv+inv1+inv2\n",
        "\n",
        "arr = [2,4,1,3,5]\n",
        "_, count = merge_count(arr)\n",
        "print(count)"
