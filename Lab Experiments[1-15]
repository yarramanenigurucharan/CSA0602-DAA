      "source": [
        "def binary_search(arr, low, high, key):\n",
        "    if low <= high:\n",
        "        mid = (low + high) // 2\n",
        "\n",
        "        if arr[mid] == key:\n",
        "            return mid\n",
        "        elif arr[mid] > key:\n",
        "            return binary_search(arr, low, mid - 1, key)\n",
        "        else:\n",
        "            return binary_search(arr, mid + 1, high, key)\n",
        "\n",
        "    return -1\n",
        "\n",
        "\n",
        "arr = [5, 10, 15, 20, 25]\n",
        "key = 20\n",
        "\n",
        "result = binary_search(arr, 0, len(arr) - 1, key)\n",
        "\n",
        "if result != -1:\n",
        "    print(\"Key found at index\", result)\n",
        "else:\n",
        "    print(\"Key not found\")"
      ],
