        "def linear_search(arr, key):\n",
        "    for i in range(len(arr)):\n",
        "        if arr[i] == key:\n",
        "            return i\n",
        "    return -1\n",
        "\n",
        "\n",
        "arr = [10, 25, 30, 45, 50]\n",
        "key = 30\n",
        "\n",
        "\n",
        "result = linear_search(arr, key)\n",
        "\n",
        "\n",
        "if result != -1:\n",
        "    print(\"Key found at index\", result)\n",
        "else:\n",
        "    print(\"Key not found\")"
