        "def fact_iter(n):\n",
        "    res = 1\n",
        "    for i in range(1, n+1):\n",
        "        res *= i\n",
        "    return res\n",
        "\n",
        "def fact_rec(n):\n",
        "    if n == 0 or n == 1:\n",
        "        return 1\n",
        "    return n * fact_rec(n-1)\n",
        "\n",
        "n = 5\n",
        "print(\"Iterative:\", fact_iter(n))\n",
        "print(\"Recursive:\", fact_rec(n))"
